from fastapi import FastAPI, Request
import json
from pathlib import Path

app = FastAPI()
JOBS_FILE = Path("active_jobs.json")

def load_active_jobs():
    if not JOBS_FILE.exists():
        return []
    # Lue bytesinä ja yritä UTF-8, fallback cp1252/latin-1
    raw = JOBS_FILE.read_bytes()
    for enc in ("utf-8", "cp1252", "latin-1"):
        try:
            txt = raw.decode(enc)
            if not txt.strip():
                return []
            data = json.loads(txt)

            # “paranna tiedosto” heti UTF-8:ksi jos se oli väärässä enkoodauksessa
            if enc != "utf-8":
                save_active_jobs(data)

            return data
        except Exception:
            continue
    return []

def save_active_jobs(jobs):
    # PAKOTA UTF-8 kirjoitus
    JOBS_FILE.write_text(
        json.dumps(jobs, indent=4, ensure_ascii=False),
        encoding="utf-8",
        newline="\n"
    )

@app.post("/jobs")
async def receive_job(request: Request):
    job = await request.json()

    # ignoraa ping-testit
    if job.get("ping") is True:
        return {"status": "ok", "ignored": True}

    jobs = load_active_jobs()
    jobs.append(job)
    save_active_jobs(jobs)
    return {"status": "ok", "count": len(jobs)}
